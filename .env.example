# Public frontend Convex URL. Convex usually writes this to .env.local.
VITE_CONVEX_URL=

# Convex deployment identifier used by the CLI. Convex usually writes this to .env.local.
CONVEX_DEPLOYMENT=

# Server-side demo access settings. Set real values in Convex env.
APP_PASSCODE=
DEMO_SESSION_TTL_HOURS=24

# Optional model provider configuration. Set provider secrets in Convex env.
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_FALLBACK_ENABLED=true
AI_MODEL_CLASSIFIER=
AI_MODEL_PATCHER=
AI_MODEL_REGEN=
AI_MODEL_JUDGE=
AI_MODEL_EMBEDDINGS=

# Optional validation and routing limits.
MAX_REPAIR_ATTEMPTS=2
MAX_DIRECT_MODEL_HTML_TOKENS=20000
ENABLE_PLAYWRIGHT_VALIDATION=false
PREVIEW_ORIGIN=
SCREENSHOT_STORAGE_ENABLED=false

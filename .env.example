# ---- Frontend (written to .env.local by `convex dev`) ----
# Public Convex URL used by the client.
VITE_CONVEX_URL=
# Convex deployment identifier used by the CLI.
CONVEX_DEPLOYMENT=

# ============================================================
# Everything below is set in CONVEX env, not here:
#   npx convex env set <NAME> "<value>"
# ============================================================

# ---- Required ----
# Shared demo passcode (server-side only).
APP_PASSCODE=
# At least ONE model provider key. OpenRouter alone reaches both vendors.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Optional ----
# Demo session token lifetime (hours).
DEMO_SESSION_TTL_HOURS=24

# Per-tier model overrides (defaults shown).
AI_MODEL_STRONG_ANTHROPIC=claude-opus-4-8
AI_MODEL_CHEAP_ANTHROPIC=claude-haiku-4-5
AI_MODEL_STRONG_OPENAI=gpt-5.5
AI_MODEL_CHEAP_OPENAI=gpt-5.4-mini
